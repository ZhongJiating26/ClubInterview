# ===== 应用基础配置 =====
APP_NAME=Club Interview System
APP_ENV=production
DEBUG=False
#APP_ENV=dev
#DEBUG=true

# ===== MySQL 数据库配置 =====
DB_HOST=localhost               # 数据库主机
DB_PORT=3306                    # 数据库端口
DB_USER=root                    # 数据库用户
DB_PASSWORD=                    # 数据库密码（请填写）
DB_NAME=club_interview          # 数据库名称

# ===== JWT 认证配置 =====
# 重要：生产环境必须使用强随机密钥！
# 可以使用以下命令生成：openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440         # JWT 过期时间（分钟），默认 1 天
ACCESS_TOKEN_EXPIRE_MINUTES=30  # 访问令牌过期时间（分钟）
REFRESH_TOKEN_EXPIRE_DAYS=7     # 刷新令牌过期时间（天）

# ===== 存储配置 =====
STORAGE_PROVIDER=rustfs         # 存储提供商: rustfs, local, s3
STORAGE_ENDPOINT=http://rustfs:9000           # RustFS 服务地址（Docker 内部网络）
STORAGE_PUBLIC_ENDPOINT=http://YOUR_SERVER_IP:9000  # RustFS 公开地址（前端访问用，替换为你的服务器 IP）
STORAGE_ACCESS_KEY=minioadmin   # RustFS 访问密钥
STORAGE_SECRET_KEY=minioadmin   # RustFS 密钥
STORAGE_BUCKET=club-interview   # 存储桶名称
STORAGE_ENV=production          # 环境标识

# ===== 端口配置（可选） =====
# 如果需要修改默认端口，可以在 docker-compose.yml 中修改
